# ── Логирование ──────────────────────────────────────────────────
# Уровень: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
LOG_FOLDER=logs/pytest tests/market_data/ -v
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ── Telegram ─────────────────────────────────────────────────────
# Режим: ALL / IMPORTANT / OFF
TELEGRAM_MODE=IMPORTANT
TELEGRAM_TIMEOUT_SEC=10.0
TELEGRAM_MAX_PER_MINUTE=20
TELEGRAM_DEDUP_WINDOW_SEC=300

# ── Брокер ───────────────────────────────────────────────────────
# Тип: paper / bybit
BROKER_TYPE=paper
BROKER_REQUEST_TIMEOUT_SEC=5.0
BROKER_RETRY_DELAY_SEC=1.0
BROKER_MAX_RETRIES=3
BROKER_PAPER_INITIAL_BALANCE=1000.0
BROKER_PAPER_COMMISSION_PCT=0.1
BROKER_PAPER_SLIPPAGE_PCT=0.05

# ── Рынок ────────────────────────────────────────────────────────
MARKET_PROVIDER=bybit
MARKET_TICKER=BTCUSDT
MARKET_TIMEFRAME=1h
MARKET_STALE_THRESHOLD_SEC=30
MARKET_POLL_INTERVAL_SEC=10
MARKET_RECONNECT_DELAY_SEC=1
MARKET_MAX_RECONNECT_SEC=30
MARKET_SPIKE_THRESHOLD_PCT=10.0
MARKET_MAX_SPREAD_PCT=1.0

# ── База данных ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=thebot
DB_USER=postgres
DB_PASSWORD=your_password_here